generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                String                 @id @default(uuid()) @db.Uuid
  name              String
  industry          String?
  size              String?
  growth_stage      String?
  primary_pressures String?
  created_at        DateTime               @default(now())
  assessments       Assessment[]
  documents         OrganizationDocument[]
  participants      Participant[]

  @@index([name])
}

model Assessment {
  id              String           @id @default(uuid()) @db.Uuid
  organization_id String           @db.Uuid
  cohort_name     String?
  assessment_date DateTime?
  status          AssessmentStatus @default(DRAFT)
  created_at      DateTime         @default(now())
  type            assessmenttype   @default(FULL)
  name            String           @default("NL-Assess")
  organization    Organization     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  Participant     Participant[]
  Response        Response[]

  @@index([organization_id])
  @@index([status])
  @@index([type])
}

model Participant {
  id              String       @id @default(uuid()) @db.Uuid

  /// Supabase Auth user.id (UUID). Used for authorization + org membership enforcement.
  /// Optional for now to avoid breaking existing data; should become required before production.
  user_id         String?      @db.Uuid

  organization_id String       @db.Uuid
  role            String?
  seniority_level String?
  created_at      DateTime     @default(now())
  assessment_id   String       @db.Uuid
  Assessment      Assessment   @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  Response        Response[]

  @@index([organization_id])
  @@index([user_id])
  @@index([organization_id, user_id])

  /// Enforces: one participant per user per assessment
  @@unique([assessment_id, user_id], map: "participant_unique_per_assessment_user")
}

model Question {
  id            String     @id @default(uuid()) @db.Uuid
  pillar        Pillar
  question_text String
  display_order Int
  weight        Int        @default(1)
  active        Boolean    @default(true)
  version       String     @default("1.0")
  created_at    DateTime   @default(now())
  Response      Response[]

  @@unique([pillar, display_order, version])
  @@index([pillar, active])
}

model Response {
  id             String      @id @default(uuid()) @db.Uuid
  assessment_id  String      @db.Uuid
  participant_id String      @db.Uuid
  question_id    String      @db.Uuid
  score          Int
  free_write     String?
  created_at     DateTime    @default(now())
  Assessment     Assessment  @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  Participant    Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  Question       Question    @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([assessment_id, participant_id, question_id], map: "response_unique_per_participant_question")
  @@index([assessment_id, participant_id])
  @@index([assessment_id, question_id])
}

model OrganizationDocument {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  title           String
  source_type     String
  source_url      String?
  storage_path    String?
  mime_type       String?
  text_extracted  String?
  created_at      DateTime     @default(now())
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, source_type])
}

enum Pillar {
  SYSTEM_INTEGRITY
  HUMAN_ALIGNMENT
  STRATEGIC_COHERENCE
  SUSTAINABILITY_PRACTICE
}

enum AssessmentStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum assessmenttype {
  FULL
  LITE
}