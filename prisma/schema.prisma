generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                 String                 @id @default(uuid()) @db.Uuid
  name               String
  industry           String?
  size               String?
  growth_stage       String?
  primary_pressures  String?

  /// Admin-entered website for narrative + enrichment
  website            String?

  /// Admin-pasted context about the org (what they do, ICP, offerings, etc.)
  context_notes      String?

  created_at         DateTime               @default(now())
  assessments        Assessment[]
  documents          OrganizationDocument[]
  participants       Participant[]
  show_admin_controls Boolean               @default(false)
  /// When true, Executive Insights shows a Project Scope link (AI-generated scopes per pilot).
  show_project_scope_review Boolean        @default(false)

  /// CRM: consulting pipeline stage for this client account
  crm_pipeline_stage     CrmPipelineStage  @default(NEW_PROSPECT)
  crm_stage_updated_at    DateTime?
  /// Next follow-up / action due (used for overdue alerts)
  crm_next_follow_up_at DateTime?
  crm_internal_notes    String?            @db.Text

  org_contacts   OrgContact[]
  crm_quotes     CrmQuote[]
  crm_contracts  CrmContract[]
  crm_invoices   CrmInvoice[]

  @@index([name])
  @@index([created_at])
  @@index([crm_pipeline_stage])
  @@index([crm_next_follow_up_at])
}

model Assessment {
  id                String           @id @default(uuid()) @db.Uuid
  organization_id   String           @db.Uuid
  cohort_name       String?
  assessment_date   DateTime?
  status            AssessmentStatus @default(DRAFT)
  locked_at         DateTime?
  created_at        DateTime         @default(now())
  type              assessmenttype   @default(FULL)
  name              String           @default("NL-Assess")

  /// If set, this assessment is "team-only locked" and participants do NOT choose a department.
  /// All questions should be filtered to audience = locked_department OR ALL.
  locked_department Department?

  organization       Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  Participant        Participant[]
  Response           Response[]
  narratives         AssessmentNarrative[]
  project_scopes     AssessmentProjectScope[]
  crm_quotes         CrmQuote[]

  @@index([organization_id])
  @@index([status])
  @@index([type])
  @@index([locked_department])
  @@index([organization_id, created_at])
}

model Participant {
  id String @id @default(uuid()) @db.Uuid

  /// Supabase Auth user.id (UUID). Used for authorization + org membership enforcement.
  /// Optional for now to avoid breaking existing data; should become required before production.
  user_id String? @db.Uuid

  /// Participant intake: free-text notes about where AI automation could help (used for narrative grounding)
  ai_opportunities_notes String? @db.Text

  /// Invite / participant email for onboarding before the user is linked to Supabase auth.
  email String?

  /// Hardened invite system (Option B): token stored as a hash (never store raw token)
  invite_token_hash       String?
  invite_token_expires_at DateTime?
  invite_sent_at          DateTime?
  invite_accepted_at      DateTime?

  organization_id String   @db.Uuid
  role            String?
  seniority_level String?
  created_at      DateTime @default(now())
  assessment_id   String   @db.Uuid
   completed_at   DateTime? 
  /// Department/team the participant represents (used to select variant questions).
  /// If assessment.locked_department is set, this can be null.
  department Department?

  Assessment   Assessment   @relation(fields: [assessment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  Response     Response[]

  @@unique([assessment_id, user_id], map: "participant_unique_per_assessment_user")
  @@unique([assessment_id, email], map: "participant_unique_per_assessment_email")

  @@index([organization_id])
  @@index([user_id])
  @@index([email])
  @@index([organization_id, user_id])
  @@index([assessment_id, department])
  @@index([assessment_id, created_at])
}

model Question {
  id            String     @id @default(uuid()) @db.Uuid
  pillar        Pillar
  question_text String
  display_order Int
  weight        Int        @default(1)
  active        Boolean    @default(true)
  version       String     @default("1.0")
  created_at    DateTime   @default(now())

  /// Which department this question is targeted for.
  /// - ALL = included in every assessment/department
  /// - SALES/MARKETING/etc = included when participant/assessment matches that department
  audience Department @default(ALL)

  Response      Response[]

  @@unique([pillar, display_order, version, audience])
  @@index([pillar, active])
  @@index([version, audience, active])
}

model Response {
  id             String      @id @default(uuid()) @db.Uuid
  assessment_id  String      @db.Uuid
  participant_id String      @db.Uuid
  question_id    String      @db.Uuid
  score          Int
  free_write     String?
  created_at     DateTime    @default(now())

  Assessment     Assessment  @relation(fields: [assessment_id], references: [id], onDelete: Cascade)
  Participant    Participant @relation(fields: [participant_id], references: [id], onDelete: Cascade)
  Question       Question    @relation(fields: [question_id], references: [id], onDelete: Cascade)

  @@unique([assessment_id, participant_id, question_id], map: "response_unique_per_participant_question")
  @@index([assessment_id, participant_id])
  @@index([assessment_id, question_id])
}

model AssessmentNarrative {
  id            String @id @default(uuid()) @db.Uuid
  assessment_id String @db.Uuid

  /// Version number per assessment (1, 2, 3...). Increment on each generation.
  version Int

  /// Lifecycle: DRAFT while iterating; FINAL when delivered; ARCHIVED for old/hidden versions.
  status NarrativeStatus @default(DRAFT)

  /// Hash of the canonical inputs used to generate this narrative
  /// (diagnostic results + org context + documents fingerprints).
  input_hash String

  /// Audit metadata (keep conservative; no secrets here).
  engine_version String  @default("v1.1")
  schema_version String  @default("1.0")
  prompt_version String?
  model_name     String?
  model_provider String?

  /// Structured output (guardrailed JSON). Validate with Zod before insert.
  narrative_json Json

  /// Optional human-readable render target for PDF/export.
  memo_markdown String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  Assessment Assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)

  @@unique([assessment_id, version], map: "narrative_unique_per_assessment_version")
  @@index([assessment_id, status])
  @@index([assessment_id, created_at])
  @@index([assessment_id, status, created_at])
}

/// AI-generated executive project scopes (one row per generation; latest by version).
model AssessmentProjectScope {
  id            String @id @default(uuid()) @db.Uuid
  assessment_id String @db.Uuid

  version    Int
  input_hash String

  engine_version String  @default("v1")
  schema_version String  @default("1.0")
  model_name     String?
  model_provider String?

  scope_json Json

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  Assessment Assessment @relation(fields: [assessment_id], references: [id], onDelete: Cascade)

  @@unique([assessment_id, version], map: "project_scope_unique_per_assessment_version")
  @@index([assessment_id, created_at])
}

model OrganizationDocument {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  title           String
  source_type     String
  source_url      String?
  storage_path    String?
  mime_type       String?
  text_extracted  String?
  created_at      DateTime     @default(now())
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, source_type])
  @@index([organization_id, created_at])
}

enum Pillar {
  SYSTEM_INTEGRITY
  HUMAN_ALIGNMENT
  STRATEGIC_COHERENCE
  SUSTAINABILITY_PRACTICE
}

enum Department {
  /// Included for every participant/assessment unless you explicitly choose to filter it out.
  ALL
  SALES
  MARKETING
  CUSTOMER_SUCCESS
  OPS
  REVOPS
  ENGINEERING
  PRODUCT
  GTM
}

enum AssessmentStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum assessmenttype {
  FULL
  LITE
}

enum NarrativeStatus {
  DRAFT
  FINAL
  ARCHIVED
}

/// Client consulting / sales pipeline (CRM)
enum CrmPipelineStage {
  NEW_PROSPECT
  CONSULTATION
  ASSESSMENT_ACTIVE
  ASSESSMENT_COMPLETE
  WORKSHOP_SCHEDULED
  WORKSHOP_CONDUCTED
  QUOTE_DRAFTED
  QUOTE_DELIVERED
  QUOTE_ACCEPTED
}

enum CrmQuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

model OrgContact {
  id              String       @id @default(uuid()) @db.Uuid
  organization_id String       @db.Uuid
  name            String
  email           String?
  phone           String?
  title           String?
  is_archived     Boolean      @default(false)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  organization          Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  quotes_as_signee      CrmQuote[]   @relation("QuoteSignee")
  quotes_as_billing     CrmQuote[]   @relation("QuoteBilling")

  @@index([organization_id])
  @@index([organization_id, is_archived])
}

/// Versioned services / SKU list for quoting (admin-maintained)
model PriceBook {
  id            String   @id @default(uuid()) @db.Uuid
  label         String
  is_current    Boolean  @default(false)
  /// [{ "sku": "...", "description": "...", "unit": "hour", "unit_price_cents": 10000 }]
  line_items    Json
  notes         String?
  source_filename String?
  /// Supabase Storage bucket name (e.g. price-books)
  storage_bucket String?
  /// Object path within the bucket
  storage_path   String?
  mime_type      String?
  created_at    DateTime @default(now())

  @@index([is_current])
  @@index([created_at])
}

model CrmQuote {
  id                     String          @id @default(uuid()) @db.Uuid
  organization_id        String          @db.Uuid
  assessment_id          String?         @db.Uuid
  project_scope_version  Int?
  /// Copy of project scope JSON when quote was created / last synced
  project_scope_snapshot Json?
  /// Full editable quote state: narrative, selected lines, custom lines, terms, etc.
  quote_payload          Json
  status                 CrmQuoteStatus  @default(DRAFT)
  signee_contact_id      String?         @db.Uuid
  billing_contact_id     String?         @db.Uuid
  total_cents            Int?
  valid_until            DateTime?
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  assessment   Assessment?  @relation(fields: [assessment_id], references: [id], onDelete: SetNull)
  signee       OrgContact?    @relation("QuoteSignee", fields: [signee_contact_id], references: [id], onDelete: SetNull)
  billing      OrgContact?    @relation("QuoteBilling", fields: [billing_contact_id], references: [id], onDelete: SetNull)

  crm_contracts CrmContract[]
  crm_invoices  CrmInvoice[]

  @@index([organization_id])
  @@index([organization_id, status])
  @@index([assessment_id])
}

model CrmContract {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  quote_id        String?  @db.Uuid
  title           String
  status          String   @default("DRAFT")
  body_notes      String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  quote        CrmQuote?    @relation(fields: [quote_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([status])
}

model CrmInvoice {
  id              String   @id @default(uuid()) @db.Uuid
  organization_id String   @db.Uuid
  title           String
  amount_cents    Int      @default(0)
  status          String   @default("DRAFT")
  due_date        DateTime?
  quote_id        String?  @db.Uuid
  notes           String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  quote        CrmQuote?    @relation(fields: [quote_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([status])
  @@index([due_date])
}