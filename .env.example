# Copy this file to `.env` and fill in values. Keep `.env` out of version control.
#   cp .env.example .env

# --- Database (Prisma) ---
DATABASE_URL=
DIRECT_URL=

# --- Supabase (browser-safe) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# If your project uses the newer name instead:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase (server-only; never use NEXT_PUBLIC_ for this) ---
# Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=
# Optional; default bucket name is price-books
# SUPABASE_PRICE_BOOK_BUCKET=price-books

# --- Admin allowlist (comma-separated emails) ---
NORTHLINE_ADMIN_EMAILS=

# --- Optional: public site URL for magic links / invites ---
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=

# --- Optional: Resend (participant invites from admin) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# --- Optional: Executive Insights / project scope (Anthropic) ---
# ANTHROPIC_API_KEY=
# NARRATIVE_AI_ENABLED=false
# NARRATIVE_AI_MODEL=
# NARRATIVE_WEB_CONTEXT_MODEL=
# NARRATIVE_WEB_ENRICHMENT_ENABLED=true
# ALLOW_NARRATIVE_FORCE=false
